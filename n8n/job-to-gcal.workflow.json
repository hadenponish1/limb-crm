        }
      },
      "id": "node-getclient-upd",
      "name": "Get client (update)",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [680, 340]
    },
    {
      "parameters": {
        "operation": "update",
        "calendar": { "__rl": true, "value": "c_13852afaa11bb06d2b91ea4f3d73374f4205e02ed2a8d80e41ec71dec209dde0@group.calendar.google.com", "mode": "id" },
        "eventId": "={{ $('Webhook').item.json.body.record.gcal_event_id }}",
        "updateFields": {
          "start": "={{ $('Webhook').item.json.body.record.date }}T{{ $('Webhook').item.json.body.record.time }}:00",
          "end": "={{ DateTime.fromFormat($('Webhook').item.json.body.record.date + ' ' + $('Webhook').item.json.body.record.time, 'yyyy-MM-dd HH:mm').plus({ minutes: Number($('Webhook').item.json.body.record.duration) || 60 }).toFormat(\"yyyy-MM-dd'T'HH:mm:ss\") }}",
          "summary": "={{ $json.name }} — {{ $('Webhook').item.json.body.record.title }}",
          "location": "={{ $json.address }}"
        }
      },
      "id": "node-update",
      "name": "Update event",
      "type": "n8n-nodes-base.googleCalendar",
      "typeVersion": 1,
      "position": [920, 340]
    },
    {
      "parameters": {
        "operation": "delete",
        "calendar": { "__rl": true, "value": "c_13852afaa11bb06d2b91ea4f3d73374f4205e02ed2a8d80e41ec71dec209dde0@group.calendar.google.com", "mode": "id" },
