# Copy this file to ".env" and fill in the values you need.
# Any value left blank just disables that feature (app still runs in local/demo mode).

# --- Google Maps + address autocomplete ---
# Get a key at https://console.cloud.google.com/ :
#   1. Create a project + enable billing (a card is required; there's a free monthly tier)
#   2. Enable APIs: "Maps JavaScript API" and "Places API (New)"
#   3. Create an API key, then restrict it to your site's domain (HTTP referrers)
VITE_GOOGLE_MAPS_API_KEY=

# --- Supabase (cloud persistence + login) ---
# Create a project at https://supabase.com/ , then:
#   1. Run supabase/schema.sql in the SQL Editor
#   2. Project Settings → API → copy the Project URL and the "anon public" key below
# When both are set, the app requires login and saves data to your Supabase database.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
